# Groq API Key (for LLM and translation)
GROQ_API_KEY=your_groq_api_key_here

# Sahaayak Master API Key for Frontend-Backend Auth
SAHAAYAK_API_KEY=PROTOTYPE_MASTER_KEY

# Security & Limits
ALLOWED_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60
APP_ENV=development

# Timeouts
LLM_TIMEOUT_SECONDS=15
TTS_TIMEOUT_SECONDS=10

# ── Amazon Bedrock (Optional: Primary LLM & RAG) ──────────────────────────────
# Fill in real AWS credentials to activate Bedrock.
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_TIMEOUT_SECONDS=20

# ── Amazon Polly (Optional: Premium TTS) ──────────────────────────────────────
POLLY_VOICE_ID=Aditi
